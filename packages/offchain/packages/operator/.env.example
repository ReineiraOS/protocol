# Operator (relayer) Configuration — permissionless: no registration or staking

# Private key for signing settlement transactions
PRIVATE_KEY=0x...

# Optional: address advertised to the coordinator SSE stream.
# Defaults to the address derived from PRIVATE_KEY when unset.
# OPERATOR_ADDRESS=0x...

# Coordinator service URL
COORDINATOR_URL=http://localhost:3001

# Destination chain RPC URL (Arbitrum Sepolia — where the escrow receiver lives)
RPC_URL=https://arbitrum-sepolia-rpc.publicnode.com

# Settlement entry point (Arbitrum Sepolia)
ESCROW_RECEIVER_ADDRESS=0xe0E6CC9Ee62Fa36b96eC4F50CDc462Fd14aa0fD3

# Chain the escrow receiver is deployed on
ESCROW_CHAIN_ID=421614

# Circle Iris API URL (attestation service)
IRIS_API_URL=https://iris-api-sandbox.circle.com

# Polling configuration
POLLING_INTERVAL_MS=2000
ATTESTATION_TIMEOUT_MS=300000
